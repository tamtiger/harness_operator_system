{
  "mcpServers": {
    "harness": {
      "command": "node",
      "args": ["<HARNESS_OS>/dist/index.js"],
      "disabled": false,
      "env": {
        "DOTENV_CONFIG_QUIET": "true",
        "DOTENV_LOG_LEVEL": "quiet"
      },
      "autoApprove": [
        "session_start",
        "skill_load",
        "skill_list",
        "instinct_get",
        "harness_status",
        "scope_get",
        "scope_check",
        "handoff_read",
        "feature_list_read",
        "task_list"
      ]
    }
  }
}
