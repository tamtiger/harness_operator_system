{
  "name": "Auto Refresh MCP Token",
  "version": "1.0.0",
  "description": "Tu dong refresh Keycloak token truoc khi lam viec. Neu token con han (>30 phut) thi bo qua.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File C:\\Users\\tamnt167\\.kiro\\hooks\\refresh-token.ps1"
  }
}
